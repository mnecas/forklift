# Upstream POC: CentOS Stream 10 runtime; default appliance is full CS10.
# XFS mode uses hybrid appliance: CS9 kernel+initrd + CS10 root (LIBGUESTFS_PATH via V2V_xfsCompatibility).
# Experimental — validate boot with guestfish before production use.
#
# Build from repo root:
#   podman build -f build/virt-v2v/Containerfile-upstream-dual-appliance -t forklift-virt-v2v-dual-appliance:cs .
#
# Deep-inspection pods should set LIBGUESTFS_BACKEND=direct (virt-v2v conversion uses libvirt below).

# EL9 stage: build a full appliance only to extract kernel+initrd for the hybrid.
FROM quay.io/centos/centos:stream9 AS appliance-cs9-kernel

RUN --mount=type=cache,target=/var/cache/dnf \
    dnf -y install --enablerepo=crb \
        qemu-img \
        supermin \
        libguestfs \
        libguestfs-devel \
        libguestfs-xfs \
        libguestfs-winsupport \
        kernel && \
    dnf clean all

# glibc workaround carried from Containerfile-upstream-xfs (el9 only).
RUN ( [ "$(rpm -q glibc)" = "glibc-2.34-66.el9.x86_64" ] && dnf -y downgrade glibc-2.34-65.el9.x86_64 || true )

# LIBGUESTFS_BACKEND=direct is required during appliance build (RHEL-104684).
RUN mkdir -p /usr/lib64/guestfs/appliance && \
    cd /usr/lib64/guestfs/appliance && \
    LIBGUESTFS_BACKEND=direct libguestfs-make-fixed-appliance . && \
    qemu-img convert -c -O qcow2 root root.qcow2 && \
    mv -vf root.qcow2 root

FROM quay.io/centos/centos:stream10 AS appliance-cs10

RUN --mount=type=cache,target=/var/cache/dnf \
    dnf -y install --enablerepo=crb \
        qemu-img \
        supermin \
        libguestfs \
        libguestfs-devel \
        libguestfs-xfs \
        libguestfs-winsupport \
        kernel \
        kernel-modules \
        kernel-modules-core && \
    dnf clean all

RUN mkdir -p /usr/lib64/guestfs/appliance && \
    cd /usr/lib64/guestfs/appliance && \
    LIBGUESTFS_BACKEND=direct libguestfs-make-fixed-appliance . && \
    qemu-img convert -c -O qcow2 root root.qcow2 && \
    mv -vf root.qcow2 root

FROM quay.io/centos/centos:stream9 AS builder

USER 0
RUN --mount=type=cache,target=/var/cache/dnf \
    dnf -y install --enablerepo=crb libvirt-devel golang && \
    dnf clean all

WORKDIR /app
COPY --chown=1001:0 ./ ./
ENV GOFLAGS="-mod=vendor -tags=strictfipsruntime"
ENV GOEXPERIMENT=strictfipsruntime

RUN go build -buildvcs=false -ldflags="-w -s" -o virt-v2v-monitor ./cmd/virt-v2v-monitor/virt-v2v-monitor.go
RUN go build -buildvcs=false -ldflags="-w -s" -o image-converter ./cmd/image-converter/image-converter.go
RUN go build -buildvcs=false -ldflags="-w -s" -o virt-v2v-wrapper ./cmd/virt-v2v/entrypoint.go
RUN go build -buildvcs=false -ldflags="-w -s" -o deep-inspection github.com/kubev2v/forklift/cmd/deep-inspection

FROM quay.io/centos/centos:stream10 AS runtime

RUN rm -f /etc/pki/tls/fips_local.cnf; \
    echo -e '[fips_sect]\ntls1-prf-ems-check = 0\nactivate = 1' > /etc/pki/tls/fips_local.cnf; \
    sed -i '/^\\[ crypto_policy \\]/a Options=RHNoEnforceEMSinFIPS' /etc/pki/tls/openssl.cnf

ENV PATH="$PATH:/usr/libexec"

RUN --mount=type=cache,target=/var/cache/dnf \
    mkdir /disks && \
    dnf -y install --enablerepo=crb \
        virt-v2v \
        libvirt-libs \
        libguestfs \
        libguestfs-tools \
        libguestfs-tools-c \
        libguestfs-xfs \
        libguestfs-winsupport \
        qemu-img \
        qemu-kvm \
        nbdkit \
        nbdkit-vddk-plugin \
        ca-certificates \
        sqlite-libs \
        kernel \
        kernel-modules \
        kernel-modules-core && \
    dnf clean all && \
    depmod "$(ls /lib/modules/ | tail -n1)" || true

# virtio-win: prefer Stream 10 repos, fall back to koji el9 RPM (same as Containerfile-upstream).
RUN --mount=type=cache,target=/var/cache/dnf \
    ( dnf -y install virtio-win || \
      dnf -y install https://kojihub.stream.centos.org/kojifiles/packages/virtio-win/1.9.40/1.el9/noarch/virtio-win-1.9.40-1.el9.noarch.rpm )

# catatonit: prefer package from repos, fall back to koji el9 RPM.
RUN --mount=type=cache,target=/var/cache/dnf \
    ( dnf -y install catatonit || \
      dnf -y install https://kojihub.stream.centos.org/kojifiles/packages/catatonit/0.2.0/2.el9/x86_64/catatonit-0.2.0-2.el9.x86_64.rpm )

RUN mkdir -p /home/qemu/.cache/libvirt && \
    chown -R qemu:qemu /home/qemu && \
    mkdir -p /etc/pki/CA/ && chown qemu:qemu /etc/pki/CA/

ENV HOME=/home/qemu
ENV LIBGUESTFS_BACKEND=libvirt:qemu:///session

COPY --from=appliance-cs10 /usr/lib64/guestfs/appliance /usr/lib64/guestfs/appliance
COPY --from=appliance-cs9-kernel /usr/lib64/guestfs/appliance/kernel /tmp/appliance-cs9-kernel/kernel
COPY --from=appliance-cs9-kernel /usr/lib64/guestfs/appliance/initrd /tmp/appliance-cs9-kernel/initrd
COPY --from=appliance-cs9-kernel /lib/modules /tmp/el9-kernel-modules

# Hybrid: CS9 kernel+initrd, CS10 root+README.fixed (single root.qcow2 copy).
RUN set -eux; \
    mkdir -p /usr/lib64/guestfs/appliance-hybrid; \
    cp -a /usr/lib64/guestfs/appliance/root /usr/lib64/guestfs/appliance/README.fixed /usr/lib64/guestfs/appliance-hybrid/; \
    cp -a /tmp/appliance-cs9-kernel/kernel /tmp/appliance-cs9-kernel/initrd /usr/lib64/guestfs/appliance-hybrid/

# EL9 kernel cannot use EL10 modules under /lib/modules — inject EL9 tree for xfs etc.
RUN set -eux; \
    el9_kver="$(ls -1 /tmp/el9-kernel-modules | head -1)"; \
    test -d "/tmp/el9-kernel-modules/${el9_kver}"; \
    LIBGUESTFS_BACKEND=direct virt-customize \
      -a /usr/lib64/guestfs/appliance-hybrid/root \
      --copy-in "/tmp/el9-kernel-modules/${el9_kver}:/lib/modules"

COPY --from=builder /app/virt-v2v-monitor /usr/local/bin/virt-v2v-monitor
COPY --from=builder /app/image-converter /usr/local/bin/image-converter
COPY --from=builder /app/virt-v2v-wrapper /usr/bin/virt-v2v-wrapper
COPY --from=builder /app/deep-inspection /usr/local/bin/deep-inspection

ENTRYPOINT ["/usr/libexec/catatonit/catatonit", "/usr/bin/virt-v2v-wrapper"]

ARG GIT_COMMIT=unknown
ARG BUILD_DATE=unknown

LABEL \
    com.redhat.component="forklift-virt-v2v-container" \
    name="forklift/forklift-virt-v2v-dual-appliance" \
    license="Apache License 2.0" \
    io.k8s.display-name="Forklift" \
    io.k8s.description="Forklift - Virt-V2V (CentOS Stream dual libguestfs appliance)" \
    io.openshift.tags="migration,mtv,forklift" \
    summary="Forklift - Virt-V2V hybrid appliance (CS9 kernel, CS10 root)" \
    description="Virt-v2v on CentOS Stream 10 with hybrid libguestfs appliance for XFS compatibility mode" \
    vendor="Konveyor" \
    maintainer="Forklift by Konveyor Community <forklift-dev@googlegroups.com>" \
    org.opencontainers.image.revision="$GIT_COMMIT" \
    org.opencontainers.image.created="$BUILD_DATE" \
    org.opencontainers.image.source="https://github.com/kubev2v/forklift"
